    if n >= 1000000: return f"{n/1000000:.1f}M"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if n >= 1000: return f"{n/1000:.1f}K"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    return str(n)
