@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    """Format view count for display."""
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if n >= 1_000_000:
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        return f"{n / 1_000_000:.1f}M"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if n >= 1_000:
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        return f"{n / 1_000:.1f}K"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    return str(n)
