def time_ago(ts):
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    """Return human-readable time ago string."""
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    diff = time.time() - ts
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if diff < 60:
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        return "just now"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if diff < 3600:
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        m = int(diff // 60)
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        return f"{m} minute{'s' if m != 1 else ''} ago"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if diff < 86400:
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        h = int(diff // 3600)
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        return f"{h} hour{'s' if h != 1 else ''} ago"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if diff < 2592000:
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        d = int(diff // 86400)
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        return f"{d} day{'s' if d != 1 else ''} ago"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    if diff < 31536000:
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        mo = int(diff // 2592000)
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
        return f"{mo} month{'s' if mo != 1 else ''} ago"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    y = int(diff // 31536000)
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    return f"{y} year{'s' if y != 1 else ''} ago"
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")

@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")

@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
