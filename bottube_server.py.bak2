@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    """Mark notifications as read. Send {ids: [1,2,3]} or {all: true}."""
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
    db = get_db()
@app.route("/beacon")def beacon_landing():    return render_template("beacon.html")
